# Supabase — supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (Claude) — console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001   # optional, this is the default

# Voyage AI (embeddings) — voyageai.com
VOYAGE_API_KEY=pa-...

# Mapbox — account.mapbox.com > Tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Google Places API (New) — console.cloud.google.com
GOOGLE_PLACES_API_KEY=AIza...

# Ticketmaster — developer.ticketmaster.com (optional)
TICKETMASTER_API_KEY=your_key

# Brave Search (optional — research subagent degrades gracefully without it)
BRAVE_SEARCH_API_KEY=your_key
